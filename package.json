{
  "name": "@mr-m/telegram-webapp-kit",
  "version": "2.0.2",
  "description": "Full-featured Telegram Web App SDK for React / Next.js — types, hooks, providers, and utilities",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --external react",
    "dev": "tsup src/index.ts --format cjs,esm --dts --external react --watch",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "telegram",
    "telegram-web-app",
    "twa",
    "mini-app",
    "react",
    "nextjs",
    "hooks"
  ],
  "author": "mr-m-apps",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mr-m-apps/telegram-webapp-kit.git"
  },
  "bugs": {
    "url": "https://github.com/mr-m-apps/telegram-webapp-kit/issues"
  },
  "homepage": "https://github.com/mr-m-apps/telegram-webapp-kit#readme",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "sideEffects": false
}
